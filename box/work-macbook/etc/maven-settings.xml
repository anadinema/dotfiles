<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<settings
  xmlns="http://maven.apache.org/SETTINGS/1.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd"
>
    <localRepository>${env.DEVFILES}/artifactory/maven</localRepository>
    <interactiveMode>false</interactiveMode>
    <servers>
        <server>
            <id>github-packages</id>
            <username>github</username>
            <password>${env.PKGS_GITHUB_TOKEN}</password>
        </server>
    </servers>
    <profiles>
        <profile>
            <id>default-repositories</id>
            <repositories>
                <repository>
                    <id>github-packages</id>
                    <url>${env.PKGS_GITHUB_REGISTRY_URL}</url>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </repository>
                <repository>
                    <id>confluent-packages</id>
                    <url>https://packages.confluent.io/maven/</url>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                </repository>
            </repositories>
        </profile>
    </profiles>
    <activeProfiles>
        <activeProfile>default-repositories</activeProfile>
    </activeProfiles>
</settings>
