# git checkout with picker, create if branch doesn't exists

local selection query picked branch source

selection="$(
  {
    git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null |
      while IFS= read -r b; do
        [ -n "$b" ] && printf " %s\t%s\tlocal\n" "$b" "$b"
      done

    if git remote get-url origin >/dev/null 2>&1; then
      git for-each-ref --format='%(refname:short)' refs/remotes/origin 2>/dev/null |
        while IFS= read -r rb; do
          rb="${rb#origin/}"
          echo $rb

          case "$rb" in
          HEAD) continue ;;
          dependabot/* | dependabot-*) continue ;;
          esac

          [ -n "$rb" ] && printf " %s\t%s\tremote\n" "$rb" "$rb"
        done
    fi
  } | sort -t $'\t' -k2,2 -u |
    fzf --with-nth=1 --delimiter=$'\t' --prompt='checkout> ' --height=40% --reverse --select-1 --print-query
)"

# If you hit ESC in fzf, it returns non-zero; treat that as "cancel", not an error noise
if [ $? -ne 0 ]; then
  return 1
fi

query="$(printf "%s\n" "$selection" | sed -n '1p' | xargs)"
picked="$(printf "%s\n" "$selection" | sed -n '2p')"

if [ -n "$picked" ]; then
  branch="$(printf "%s" "$picked" | cut -f2)"
  source="$(printf "%s" "$picked" | cut -f3)"
else
  branch="$query"
  source="new"
fi

[ -z "$branch" ] && return 0

# Validate branch name early
if ! git check-ref-format --branch "$branch" >/dev/null 2>&1; then
  echo "Invalid branch name: $branch"
  return 1
fi

# If it exists locally, switch
if git show-ref --verify --quiet "refs/heads/$branch"; then
  git switch "$branch"
  return $?
fi

# If selected from remote list and exists on origin, create tracking branch
if [ "$source" = "remote" ] && git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
  git switch --track -c "$branch" "origin/$branch"
  return $?
fi

# If it exists on origin but you typed it (not selected), still track it
if git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
  git switch --track -c "$branch" "origin/$branch"
  return $?
fi

# Otherwise it exists neither local nor remote => create new
git switch -c "$branch"
